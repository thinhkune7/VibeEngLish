            <property name="styleSheet">
             <string notr="true">QListWidget {
    background-color: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 10px;
    padding: 5px;
    color: #1F2937;
    font-size: 15px;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
}

QListWidget::item {
    padding: 10px;
    border-bottom: 1px solid #F3F4F6; /* Vạch kẻ mờ giữa các từ vựng */
}

QListWidget::item:selected {
    background-color: #EFF6FF; /* Highlight màu xanh nhạt khi chọn 1 từ */
    color: #1D4ED8;
    border-radius: 5px;
}
QListWidget QScrollBar:vertical {
    border: none;
    background-color: #F9FAFB; /* Nền rãnh trượt hơi xám rất nhẹ để phân biệt */
    width: 12px;
    margin: 0px;
    border-radius: 6px;
}

/* CỤC TẨY (THANH NẮM) KÉO LÊN XUỐNG */
QListWidget QScrollBar::handle:vertical {
    background-color: #6B7280; /* XÁM ĐẬM - Cực kỳ dễ nhìn */
    min-height: 40px;          /* Cho thanh nắm dài ra một chút để dễ bấm */
    border-radius: 6px;
    margin: 2px;
}

/* KHI ĐƯA CHUỘT VÀO THANH CUỘN */
QListWidget QScrollBar::handle:vertical:hover {
    background-color: #4B5563; /* Đậm màu hơn */
}

/* KHI CLICK VÀ NHẤN GIỮ */
QListWidget QScrollBar::handle:vertical:pressed {
    background-color: #374151; /* Gần như đen */
}

/* ẨN 2 NÚT MŨI TÊN LÊN/XUỐNG ĐỂ TRÔNG HIỆN ĐẠI HƠN */
QListWidget QScrollBar::add-line:vertical, 
QListWidget QScrollBar::sub-line:vertical {
    height: 0px;
    background: none;
}

QListWidget QScrollBar::add-page:vertical, 
QListWidget QScrollBar::sub-page:vertical {
    background: none;
}</string>
