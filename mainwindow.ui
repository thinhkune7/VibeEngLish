}

/* Đảm bảo khung chứa nội dung con bên trong cũng màu trắng đồng bộ */
QScrollArea &gt; QWidget &gt; QWidget {
    background-color: #FFFFFF; 
}


/* =======================================================
   2. THANH CUỘN DỌC (VERTICAL SCROLLBAR)
======================================================== */
QScrollBar:vertical {
    border: none;
    background-color: #F9FAFB; /* Rãnh cuộn màu xám cực nhạt để dễ nhận biết */
    width: 10px;               /* Độ dày của thanh cuộn */
    margin: 0px;
    border-radius: 5px;        /* Bo góc rãnh cuộn */
}

/* KHỐI NẮM TRƯỢT (CỤC TẨY) */
QScrollBar::handle:vertical {
    background-color: #9CA3AF; /* Màu xám nổi bật trên nền trắng */
    min-height: 40px;          
    border-radius: 5px;        
}

/* KHI ĐƯA CHUỘT VÀO (HOVER) */
QScrollBar::handle:vertical:hover {
    background-color: #6B7280; /* Đậm màu hơn khi di chuột */
}

/* KHI NHẤN GIỮ KÉO (PRESSED) */
QScrollBar::handle:vertical:pressed {
    background-color: #4B5563; /* Đậm nhất khi đang kéo */
}

/* ẨN 2 NÚT MŨI TÊN (Lên/Xuống) */
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px; 
    background: none;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none; 
}</string>
